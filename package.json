{
  "name": "hexcore-capstone",
  "version": "1.3.1",
  "description": "Modern Node.js bindings for Capstone disassembler engine using N-API",
  "main": "./index.js",
  "module": "./index.mjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "import": "./index.mjs",
      "require": "./index.js",
      "types": "./index.d.ts"
    }
  },
  "scripts": {
    "install": "prebuild-install -r napi || node-gyp rebuild",
    "build": "npm run build:deps && node-gyp rebuild",
    "build:debug": "node-gyp rebuild --debug",
    "prebuild": "npm run build:deps && prebuildify --napi --strip",
    "prebuild:all": "prebuildify-cross -i centos7-devtoolset7 -i alpine -i linux-armv7 -i linux-arm64",
    "test": "node test/test.js",
    "clean": "node-gyp clean",
    "prepare": "npm run build",
    "build:deps": "cmake -S deps/capstone -B deps/capstone/build -DCMAKE_BUILD_TYPE=Release -DCAPSTONE_BUILD_TESTS=OFF -DCAPSTONE_BUILD_SHARED=OFF && cmake --build deps/capstone/build --config Release"
  },
  "keywords": [
    "capstone",
    "disassembler",
    "disassembly",
    "reverse-engineering",
    "binary-analysis",
    "x86",
    "x64",
    "arm",
    "arm64",
    "mips",
    "ppc",
    "sparc",
    "m68k",
    "riscv",
    "native",
    "napi",
    "async"
  ],
  "author": "HikariSystem <hikarisystem@example.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LXrdKnowkill/hexcore-capstone.git"
  },
  "bugs": {
    "url": "https://github.com/LXrdKnowkill/hexcore-capstone/issues"
  },
  "homepage": "https://github.com/LXrdKnowkill/hexcore-capstone#readme",
  "engines": {
    "vscode": "^1.0.0",
    "node": ">=18.0.0"
  },
  "activationEvents": [],
  "dependencies": {
    "node-addon-api": "^7.0.0",
    "prebuild-install": "^7.1.1"
  },
  "devDependencies": {
    "node-gyp": "^10.0.0",
    "prebuildify": "^6.0.0"
  },
  "files": [
    "src/",
    "deps/capstone/*.c",
    "deps/capstone/*.h",
    "deps/capstone/include/",
    "deps/capstone/arch/",
    "prebuilds/",
    "binding.gyp",
    "index.js",
    "index.mjs",
    "index.d.ts",
    "README.md"
  ],
  "binary": {
    "napi_versions": [
      8
    ]
  }
}
